# ─────────────────────────────────────────────────
# Medway Hub — Environment Variables
# ─────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores

# ── Banco de dados ────────────────────────────────
# SQLite local (desenvolvimento)
DATABASE_URL="file:./prisma/dev.db"

# Para Turso (produção recomendada no Vercel):
# DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── NextAuth ──────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"

# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ── SSO Token ─────────────────────────────────────
# Gere com: openssl rand -base64 32
# IMPORTANTE: este secret deve ser o MESMO nos projetos externos
# que usam exports/middleware.ts para validação offline do token
SSO_SECRET=""

# ── Seed ─────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@medway.com.br"
SEED_ADMIN_PASSWORD="troque-em-producao"
SEED_ADMIN_NAME="Administrador Medway"
